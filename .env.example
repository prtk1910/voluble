# Public application origin, with no trailing slash.
# Use port 3000 with `vercel dev --listen 3000`.
APP_URL=http://localhost:3000

# Google OAuth 2.0 web application credentials.
# Authorized redirect URI: ${APP_URL}/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Numeric Google Cloud project number (not project ID) and browser-restricted Picker API key.
GOOGLE_CLOUD_PROJECT=
GOOGLE_PICKER_API_KEY=

# Full Cloud KMS CryptoKey resource name.
GOOGLE_KMS_KEY_NAME=projects/PROJECT_ID/locations/LOCATION/keyRings/KEY_RING/cryptoKeys/KEY_NAME

# Production on Vercel: short-lived GCP credentials through Workload Identity Federation.
# Leave unset locally to use Application Default Credentials.
GCP_PROJECT_NUMBER=
GCP_SERVICE_ACCOUNT_EMAIL=
GCP_WORKLOAD_IDENTITY_POOL_ID=vercel
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=vercel

# PostgreSQL connection string. Vercel/Neon integrations may inject this.
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Generate with: openssl rand -base64 48
SESSION_SECRET=

# Optional locally when `gcloud auth application-default login` is not used.
# Omit when the runtime already provides Application Default Credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional override. Leave unset to use gpt-5.4-mini-2026-03-17.
# OPENAI_CLEANUP_MODEL=gpt-5.4-mini-2026-03-17

# OpenAI and Gemini user API keys are entered in Voluble Settings.
# Do not add them to this file.
